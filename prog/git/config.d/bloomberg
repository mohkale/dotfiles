# Bloomberg specific git configuration -*- gitconfig -*-

[user]
	email = mkaleem2@bloomberg.net
[init]
	defaultBranch = main
[core]
	# Properly handle the executable file permission when on a file-system
	# interchanging between windows and ext4 file-systems (such as WSL).
    filemode = false
	# Smartly handles windows CRLF line endings between windows and linux systems.
	autocrlf = input

# bb-github overrides just like regular Github.
[bbgithub]
	user = mkaleem2
[url "git@bbgithub.dev.bloomberg.com:"]
    insteadOf = https://bbgithub.dev.bloomberg.com/
[url "git@bbgithub.dev.bloomberg.com:"]
    insteadOf = bbgithub:
[url "https://git.savannah.gnu.org/git/"]
    insteadOf = "git://git.savannah.gnu.org/"

# Note: See [[https://tutti.prod.bloomberg.com/bbgithub/configuration][here]] for how to setup proxy access for github and gitlab repos.

# BB proxy configuration for extra git remotes I use for Emacs packages
[http "https://github.com"]
    proxy = http://proxy.bloomberg.com:81
    sslCAinfo = ~/.config/certificates/bloomberg-root-ca.crt
[http "https://gitlab.com"]
    proxy = http://proxy.bloomberg.com:81
    sslCAinfo = ~/.config/certificates/bloomberg-root-ca.crt
[http "https://git.sr.ht/~iank/visible-mark"]
    proxy = http://proxy.bloomberg.com:81
    sslCAinfo = ~/.config/certificates/bloomberg-root-ca.crt
[http "https://git.savannah.gnu.org"]
	proxy = http://proxy.bloomberg.com:81
	sslCAinfo = ~/.config/certificates/bloomberg-root-ca.crt
[http "https://codeberg.org/ideasman42"]
	proxy = http://proxy.bloomberg.com:81
	sslCAinfo = ~/.config/certificates/bloomberg-root-ca.crt
[http "https://depp.brause.cc"]
	proxy = http://proxy.bloomberg.com:81
	sslCAinfo = ~/.config/certificates/bloomberg-root-ca.crt
[http "https://mumble.net/~campbell/git"]
	proxy = http://proxy.bloomberg.com:81
	sslCAinfo = ~/.config/certificates/bloomberg-root-ca.crt
[http "https://git.sr.ht/~bzg/org-contrib"]
	proxy = http://proxy.bloomberg.com:81

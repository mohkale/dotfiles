# -*- conf-space -*-

bce                    bbcmake-env
alb@file               $XDG_CONFIG_HOME/aliases/bloomberg
bbprofile@file         $XDG_CONFIG_HOME/bbprofile
bb@dirx                $XDG_DEV_HOME/repos/bloomberg

# im                     bb-local-dev magic
# im-mds                 bb-local-dev --distribution=mds-unstable
# ide-magic-compose      bb-local-dev compose
# imc                    ide-magic-compose
cm                     container-maintainer

dd-rapi3tool           docker run --rm -v "$(pwd -P):/workarea" -v "/tmp:/mnttmp:ro" -e USER="${USER}" -e KRB5CCNAME="/mnttmp/krb5cc_$(id -u $USER)" -it artprod.dev.bloomberg.com/training/rapi3tool:latest rapi3tool

# dev-compose wrappers.
im                     ide-magic
imi                    dev-compose --log-level=DEBUG install
imc                    dev-compose compose
imx                    [ -e .lcldev/dev-compose ] && rm -rvf .lcldev/dev-compose
# Weekly refresh helpers
weekly-refresh                 weekly-erase-docker-cache; weekly-erase-build-cache; weekly-fetch-repos; weekly-rebuild-project-images
weekly-erase-docker-cache      sudo service docker restart && dd-erase-all
weekly-erase-build-cache       ls-projects | sort -u | awk -F : -e '{ printf("%s/cmake-build\n", $1); printf("%s/cmake-install\n", $1) }' | parallel [ -e {} ] '&&' rm -rvf {}
weekly-rebuild-project-images  ls-projects | sort -u | parallel --colsep=: [ -e {1}/.lcldev/dev-compose/docker-compose.yml ] '&&' echo {1} | grep -E 'testtrep|feedadapter|feedadapter-rules' | parallel --ungroup --colsep=: --max-procs=1 cd {1} '&&' echo {2} '&&' dev-compose compose pull '&&' dev-compose compose build --pull --parallel
weekly-fetch-repos             ls-projects | sort -u | parallel --max-procs=1 --colsep=: echo {2} '&&' cd {1} '&&' git fetch --all

# Dev machine helpers

ki                     kinit mkaleem2@ADDEV.BLOOMBERG.COM
ks                     klist

# Development hosts.
fai-dev-1@ssh          fai-dev-1
fai-dev-2@ssh          fai-dev-2
fai-dev-3@ssh          fai-dev-3
fai-dev-4@ssh          fai-dev-4
epslnjapmddap01@ssh    EPSLNJAPMDDAP01
epslnyapmddap01@ssh    EPSLNYAPMDDAP01

faisvc@sshx            getprdwin -i FAISVC
faisva@sshx            getprdwin -i FAISVA
faisva-pw-579@sshx     getprdwin -i FAISVA-PW-579
faisva-ob-309@sshx     getprdwin -i FAISVA-OB-309
faisvb@sshx            getprdwin -i FAISVB

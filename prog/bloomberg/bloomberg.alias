mddapd-tt-006@ssh      MDDAPD-TT-006
gnrld-pw-569@ssh       gnrld-pw-569

# Gateway machine.
ony-bam1@sshx          ssh -x -2 -t mkaleem2@10.117.4.16 inline ony-bam1

